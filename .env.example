# ─── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Server ────────────────────────────────────────────────────
PORT=3100

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4000

# ─── Project API URLs ─────────────────────────────────────────
# Set these to match your project's API endpoints.
# The ZeroTrusted example project uses these:
#
# SettingsApiUrl=https://your-settings-api.example.com
# HealthCheckApiUrl=https://your-health-check-api.example.com
# MlAPINewBaseUrl=https://your-ml-api.example.com
# MlAPIRagBaseUrl=https://your-rag-api.example.com
# GatewayHost=https://your-gateway.example.com
# HistoryApiUrl=https://your-history-api.example.com
# IdentityDomain=https://your-identity.example.com
# NotificationAPIBaseUrl=https://your-notification-api.example.com
